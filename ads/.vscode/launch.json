{
  "configurations": [
    {
      "command": "./node_modules/.bin/astro dev",
      "name": "Development server",
      "request": "launch",
      "type": "node-terminal"
    },
    {
      "address": "127.0.0.1",
      "localRoot": "${workspaceFolder}",
      "name": "Attach to Astro",
      "port": 9229,
      "remoteRoot": "${workspaceFolder}",
      "request": "attach",
      "restart": true,
      "skipFiles": [
        "\u003cnode_internals\u003e/**"
      ],
      "type": "node"
    }
  ],
  "version": "0.2.0"
}
